# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ndma_dcs_portal

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-minimum-32-chars
BETTER_AUTH_URL=http://localhost:3000

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Web App ─────────────────────────────────────────────────────────────────
VITE_SERVER_URL=http://localhost:3000

# ─── LDAP / Active Directory (Phase 2) ───────────────────────────────────────
# LDAP_URL=ldap://your-ad-server:389
# LDAP_BIND_DN=cn=service-account,dc=ndma,dc=gov
# LDAP_BIND_CREDENTIALS=your-service-account-password
# LDAP_SEARCH_BASE=dc=ndma,dc=gov
