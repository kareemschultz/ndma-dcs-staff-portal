{
  "name": "ndma-dcs-staff-portal",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.5",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@orpc/client": "^1.12.2",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @ndma-dcs-staff-portal/db db:push",
    "db:studio": "turbo -F @ndma-dcs-staff-portal/db db:studio",
    "db:generate": "turbo -F @ndma-dcs-staff-portal/db db:generate",
    "db:migrate": "turbo -F @ndma-dcs-staff-portal/db db:migrate",
    "db:start": "turbo -F @ndma-dcs-staff-portal/db db:start",
    "db:watch": "turbo -F @ndma-dcs-staff-portal/db db:watch",
    "db:stop": "turbo -F @ndma-dcs-staff-portal/db db:stop",
    "db:down": "turbo -F @ndma-dcs-staff-portal/db db:down"
  },
  "dependencies": {
    "@ndma-dcs-staff-portal/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ndma-dcs-staff-portal/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11"
}
